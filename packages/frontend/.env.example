# Copy this file to .env and fill in your own values.
# .env is gitignored and should never be committed.

# API base URL used by the production build.
# In dev the Vite proxy is used automatically.
VITE_API_BASE_URL=https://filesync-api.example.com/api

# Optional: enable frontend auto-destroy UI
VITE_FEATURE_FRONTEND_AUTO_DESTROY=true
